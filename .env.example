# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com
SECURE_COOKIES=true

# Security
ALLOW_BASIC_AUTH=false
VERIFY_EMAIL_TOKEN_HOURS=24
RATELIMIT_DEFAULT_LIMIT=10
RATELIMIT_DEFAULT_PERIOD=900
THROTTLE_SIGN_PDF=60/hour
THROTTLE_SIGN_PDF_BURST=10/min
THROTTLE_AGENT_PAIR=10/hour
API_SIGN_MAX_UPLOAD_MB=10
TRUSTED_PROXY_COUNT=0
CACHE_BACKEND=database
USB_AGENT_ALLOWED_ORIGINS=

# Database (omit for local SQLite)
DATABASE_URL=postgres://dscapi:dscapi@db:5432/dscapi

# SaaS
SITE_URL=https://yourdomain.com
DEFAULT_MONTHLY_QUOTA=100
# Required when DEBUG=false (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Email — Microsoft Outlook / Microsoft 365 SMTP
# Business (Microsoft 365): smtp.office365.com
# Personal (@outlook.com/@hotmail.com): smtp-mail.outlook.com
# Requirements:
#   - DEFAULT_FROM_EMAIL must match EMAIL_HOST_USER (same mailbox)
#   - In Microsoft 365 admin: enable "Authenticated SMTP" for this mailbox
#     (Users → mailbox → Mail → Manage email apps → Authenticated SMTP)
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@yourdomain.com
EMAIL_HOST_PASSWORD=your-mailbox-password
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=30
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Bootstrap Django admin (used by docker/entrypoint.sh on first deploy)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me
ADMIN_USERNAME=admin
