# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com
SECURE_COOKIES=true

# Database (omit for local SQLite)
DATABASE_URL=postgres://dscapi:dscapi@db:5432/dscapi

# SaaS
SITE_URL=https://yourdomain.com
DEFAULT_MONTHLY_QUOTA=100
ENCRYPTION_KEY=

# Email (SMTP) — required for registration verification in production
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Bootstrap Django admin (used by docker/entrypoint.sh on first deploy)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me
ADMIN_USERNAME=admin
