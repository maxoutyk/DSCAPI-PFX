# Production .env for sign.incitegravity.com
# Copy on server: sudo -u dscapi cp deploy/env.incitegravity.example /opt/dscapi/.env

DOMAIN=sign.incitegravity.com
SECRET_KEY=replace-with-generated-secret
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgres://dscapi:replace-with-strong-password@127.0.0.1:5432/dscapi

DEBUG=false
ALLOWED_HOSTS=sign.incitegravity.com
CSRF_TRUSTED_ORIGINS=https://sign.incitegravity.com
SECURE_COOKIES=true
SECURE_HSTS_SECONDS=31536000
SITE_URL=https://sign.incitegravity.com

# Security (required in production)
ENCRYPTION_KEY=replace-with-generated-fernet-key
ALLOW_BASIC_AUTH=false
VERIFY_EMAIL_TOKEN_HOURS=24
PASSWORD_RESET_TOKEN_HOURS=2
RATELIMIT_DEFAULT_LIMIT=10
RATELIMIT_DEFAULT_PERIOD=900
THROTTLE_SIGN_PDF=60/hour
THROTTLE_SIGN_PDF_BURST=10/min
SESSION_COOKIE_AGE=604800

ADMIN_EMAIL=admin@incitegravity.com
ADMIN_PASSWORD=replace-with-strong-password
ADMIN_USERNAME=admin

# Microsoft 365 / Outlook SMTP
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@incitegravity.com
EMAIL_HOST_PASSWORD=replace-with-mailbox-password
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=30
DEFAULT_FROM_EMAIL=noreply@incitegravity.com

DEFAULT_MONTHLY_QUOTA=100
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120
