# Copy to .env on the server: cp deploy/env.production.example .env
#
# Native nginx install: use a subdomain (sign.yourdomain.com), gunicorn on 127.0.0.1:8081
# Docker install:       use docker-compose.prod.yml with Caddy instead

# --- Required ---
DOMAIN=sign.yourdomain.com
SECRET_KEY=generate-with-setup-script
ENCRYPTION_KEY=generate-with-setup-script
POSTGRES_PASSWORD=generate-a-strong-password
# Native server (local PostgreSQL):
DATABASE_URL=postgres://dscapi:generate-a-strong-password@127.0.0.1:5432/dscapi

DEBUG=false
ALLOWED_HOSTS=sign.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://sign.yourdomain.com
SECURE_COOKIES=true
ALLOW_BASIC_AUTH=false
VERIFY_EMAIL_TOKEN_HOURS=24
RATELIMIT_DEFAULT_LIMIT=10
RATELIMIT_DEFAULT_PERIOD=900
THROTTLE_SIGN_PDF=60/hour
THROTTLE_SIGN_PDF_BURST=10/min
SITE_URL=https://sign.yourdomain.com

# --- Admin (created on first container start) ---
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-strong-password
ADMIN_USERNAME=admin

# --- Microsoft Outlook / Microsoft 365 SMTP ---
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@yourdomain.com
EMAIL_HOST_PASSWORD=your-mailbox-password
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=30
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# --- Optional ---
DEFAULT_MONTHLY_QUOTA=100
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120
